{
  "$schema": "../node_modules/wrangler/config-schema.json",
  "name": "nutsnews-worker-16",
  "main": "../src/index.ts",
  "compatibility_date": "2026-06-10",
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "workers_dev": true,
  "preview_urls": false,
  "observability": {
    "enabled": true
  },
  "vars": {
    "FEED_SHARD_INDEX": "16",
    "FEEDS_PER_SHARD": "20",
    "ENABLED_SUMMARY_LANGUAGES": "fr,ja,de-CH,de,el",
    "SUMMARY_TRANSLATION_LIMIT": "5",
    "HOLD_ARTICLES_FOR_TRANSLATIONS": "true",
    "PUBLIC_FEED_EDGE_SNAPSHOT_LIMIT": "120",
    "PUBLIC_FEED_EDGE_SNAPSHOT_TTL_SECONDS": "604800"
  },
  "secrets_store_secrets": [
    {
      "binding": "SUPABASE_URL",
      "store_id": "0d4e0e193d414b9f8bcbca44c6af24f9",
      "secret_name": "SUPABASE_URL"
    },
    {
      "binding": "SUPABASE_SERVICE_ROLE_KEY",
      "store_id": "0d4e0e193d414b9f8bcbca44c6af24f9",
      "secret_name": "SUPABASE_SERVICE_ROLE_KEY"
    },
    {
      "binding": "OPENAI_API_KEY",
      "store_id": "0d4e0e193d414b9f8bcbca44c6af24f9",
      "secret_name": "OPENAI_API_KEY"
    },
    {
      "binding": "BETTER_STACK_SOURCE_TOKEN",
      "store_id": "0d4e0e193d414b9f8bcbca44c6af24f9",
      "secret_name": "BETTER_STACK_SOURCE_TOKEN"
    },
    {
      "binding": "BETTER_STACK_INGESTING_HOST",
      "store_id": "0d4e0e193d414b9f8bcbca44c6af24f9",
      "secret_name": "BETTER_STACK_INGESTING_HOST"
    }
  ],
  "kv_namespaces": [
    {
      "binding": "NUTSNEWS_KV",
      "id": "6e981f0941eb46ac8202a0a64e8eeb26",
      "preview_id": "6e981f0941eb46ac8202a0a64e8eeb26"
    }
  ]
}
