{
  "$schema": "../node_modules/wrangler/config-schema.json",
  "name": "nutsnews-worker-24",
  "main": "../src/index.ts",
  "compatibility_date": "2026-06-10",
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "workers_dev": true,
  "preview_urls": false,
  "observability": {
    "enabled": true
  },
  "vars": {
    "FEED_SHARD_INDEX": "24",
    "FEEDS_PER_SHARD": "20",
    "SENTRY_ENVIRONMENT": "production",
    "SENTRY_TRACES_SAMPLE_RATE": "0.1"
  },
  "secrets_store_secrets": [
    {
      "binding": "SUPABASE_URL",
      "store_id": "0d4e0e193d414b9f8bcbca44c6af24f9",
      "secret_name": "SUPABASE_URL"
    },
    {
      "binding": "SUPABASE_SERVICE_ROLE_KEY",
      "store_id": "0d4e0e193d414b9f8bcbca44c6af24f9",
      "secret_name": "SUPABASE_SERVICE_ROLE_KEY"
    },
    {
      "binding": "OPENAI_API_KEY",
      "store_id": "0d4e0e193d414b9f8bcbca44c6af24f9",
      "secret_name": "OPENAI_API_KEY"
    },
    {
      "binding": "SENTRY_DSN",
      "store_id": "0d4e0e193d414b9f8bcbca44c6af24f9",
      "secret_name": "SENTRY_DSN"
    }
  ]
}
