{
  "$schema": "../node_modules/wrangler/config-schema.json",
  "name": "nutsnews-worker-0-local",
  "main": "../src/index.ts",
  "compatibility_date": "2026-06-10",
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "workers_dev": true,
  "preview_urls": false,
  "observability": {
    "enabled": true
  },
  "vars": {
    "FEED_SHARD_INDEX": "0",
    "FEEDS_PER_SHARD": "20"
  }
}
