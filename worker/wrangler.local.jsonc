{
	"$schema": "node_modules/wrangler/config-schema.json",
	"name": "nutsnews-worker-local",
	"main": "src/index.ts",
	"compatibility_date": "2026-06-01",
	"workers_dev": true,
	"vars": {
		"FEED_SHARD_INDEX": "0",
		"FEEDS_PER_SHARD": "20",
		"OPENAI_INPUT_COST_PER_1M_TOKENS": "0.15",
		"OPENAI_OUTPUT_COST_PER_1M_TOKENS": "0.60",
		"AI_COST_ALERT_RUN_USD": "0.05",
		"AI_REVIEW_ALERT_RUN_LIMIT": "12",
		"AI_TOKEN_ALERT_RUN_LIMIT": "50000",
		"ENABLED_SUMMARY_LANGUAGES": "fr,ja,de-CH,de,el",
		"SUMMARY_TRANSLATION_LIMIT": "12"
	}
}
