{
  "schemaVersion": 1,
  "title": "NutsNews admin backend operation contract",
  "sourceOfTruth": {
    "repository": "ramideltoro/nutsnews",
    "contractFile": "api-contracts/admin-backend-operations.json",
    "typescriptAllowlist": "web/lib/adminDatabase.ts#ADMIN_DATABASE_READ_OPERATIONS",
    "validation": "tests/admin-backend-operation-contract.test.mjs"
  },
  "backendConsumption": {
    "backendRepository": "ramideltoro/nutsnews-backend",
    "routePattern": "/api/app/db/{operation}",
    "notes": "Backend compatibility checks should consume this JSON file directly and mirror every read operation in the backend app database API allowlist. Do not scrape TypeScript source for cross-repo compatibility."
  },
  "defaults": {
    "method": "POST",
    "classification": "read",
    "safeRead": true,
    "allowedProviderModes": [
      "backend_postgres_shadow",
      "backend_postgres_primary"
    ],
    "auth": "protected admin server session plus backend API bearer token",
    "responseEnvelope": {
      "type": "AdminDatabaseRowsResult",
      "requiredFields": [
        "rows"
      ],
      "optionalFields": [
        "rowCount",
        "generatedAt"
      ]
    }
  },
  "operations": [
    {
      "operation": "load-admin-production-readiness",
      "dashboardRoute": "/admin/readiness",
      "dashboardFile": "web/app/admin/(protected)/readiness/page.tsx",
      "loaderFile": "web/lib/adminProductionReadiness.ts",
      "backendPath": "/api/app/db/load-admin-production-readiness",
      "method": "POST",
      "classification": "read",
      "safeRead": true,
      "allowedProviderModes": [
        "backend_postgres_shadow",
        "backend_postgres_primary"
      ],
      "responseShape": {
        "rows": "single dashboard snapshot row",
        "minimalRowFields": [
          "articleCount",
          "publicFeedSnapshotCount",
          "recentArticles",
          "workerRun",
          "articlesLast24Hours",
          "articlesLast7Days",
          "translationSummaries",
          "translationExpectedCount"
        ]
      }
    },
    {
      "operation": "load-admin-article-reviews",
      "dashboardRoute": "/admin/articles",
      "dashboardFile": "web/app/admin/(protected)/articles/page.tsx",
      "loaderFile": "web/lib/adminArticleReviews.ts",
      "backendPath": "/api/app/db/load-admin-article-reviews",
      "method": "POST",
      "classification": "read",
      "safeRead": true,
      "allowedProviderModes": [
        "backend_postgres_shadow",
        "backend_postgres_primary"
      ],
      "responseShape": {
        "rows": "single dashboard snapshot row",
        "minimalRowFields": [
          "sourceOptions",
          "categoryOptions",
          "recentPublishedArticleRows",
          "recentPublishedReviewRows",
          "versionReportRows",
          "reviewRows",
          "publishedArticlesForReviews",
          "totalMatchingReviews"
        ]
      }
    },
    {
      "operation": "load-admin-article-engagement",
      "dashboardRoute": "/admin/engagement",
      "dashboardFile": "web/app/admin/(protected)/engagement/page.tsx",
      "loaderFile": "web/lib/adminArticleEngagement.ts",
      "backendPath": "/api/app/db/load-admin-article-engagement",
      "method": "POST",
      "classification": "read",
      "safeRead": true,
      "allowedProviderModes": [
        "backend_postgres_shadow",
        "backend_postgres_primary"
      ],
      "responseShape": {
        "rows": "single dashboard snapshot row",
        "minimalRowFields": [
          "sourceCategoryRows",
          "articleRows",
          "sourceCategoryError",
          "articleError"
        ]
      }
    },
    {
      "operation": "load-admin-ai-usage",
      "dashboardRoute": "/admin/ai-usage",
      "dashboardFile": "web/app/admin/(protected)/ai-usage/page.tsx",
      "loaderFile": "web/lib/adminAiUsage.ts",
      "backendPath": "/api/app/db/load-admin-ai-usage",
      "method": "POST",
      "classification": "read",
