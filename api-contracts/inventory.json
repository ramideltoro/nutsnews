      "id": "articles",
      "method": ["GET"],
      "path": "/api/articles",
      "routeFile": "web/app/api/articles/route.ts",
      "request": {
        "body": "none",
        "query": {
          "page": "optional number; invalid or negative becomes 0; floored and capped at 1000",
          "cursor": "optional non-empty opaque cursor; selects cursor pagination unless home=1",
          "home": "optional; only value 1 selects home-feed mode and overrides cursor",
          "category": "optional string; blank or all means no category filter",
          "lang": "optional enum en|fr|ja|de-CH|de|el; invalid values normalize to en",
          "limit": "accepted but intentionally ignored for backward compatibility; the fixed offset page size is 5"
        }
      },
      "auth": "public; no authentication or authorization is required",
      "successStatus": [200],
      "successResponseShape": {
        "contentType": "application/json",
        "requiredKeys": ["articles", "nextPage", "nextCursor", "dataSource", "languageCode"],
        "article": {
          "required": {
            "id": "string",
            "source": "string",
            "title": "string",
            "original_url": "string",
            "language_code": "string",
            "requested_language_code": "string",
            "translation_available": "boolean"
          },
          "nullable": {
            "image_url": "string|null",
            "published_at": "string|null",
            "published_on_site_at": "string|null",
            "ai_summary": "string|null",
            "category": "string|null",
            "positivity_score": "number|null"
          }
        },
        "enums": {
          "dataSource": ["public_feed_snapshot", "articles_fallback", "edge_feed_snapshot"],
          "languageCode": ["en", "fr", "ja", "de-CH", "de", "el"]
        },
        "homeMode": {
          "additionalRequiredKey": "sections",
          "sectionIdsInOrder": ["community", "animals", "science", "wellness", "travel", "culture", "achievements"]
        }
      },
      "errorStatuses": [500],
      "errorShape": {
        "requiredKeys": ["articles", "nextPage", "nextCursor", "error"],
        "articles": "[]",
        "nextPage": null,
        "nextCursor": null,
        "homeModeAdditionalRequiredKey": "sections"
      },
      "pagination": {
        "offset": "nextPage is number|null; offset ordering is source-defined and must remain stable for a response sequence",
        "cursor": "nextCursor is string|null; cursor requests retain nextPage:null",
        "home": "home=1 is a non-paginated combined payload; nextCursor may be present for compatibility"
      },
      "cache": "public JSON cache; route emits Cache-Control, CDN cache headers, and X-NutsNews article metadata headers",
