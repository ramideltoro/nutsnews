{
  "name": "web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --webpack",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "test:accessibility": "playwright test --config=playwright.accessibility.config.ts",
    "audit:pagespeed": "node scripts/pagespeed-insights.mjs --strategy=both",
    "audit:pagespeed:mobile": "node scripts/pagespeed-insights.mjs --strategy=mobile",
    "audit:pagespeed:desktop": "node scripts/pagespeed-insights.mjs --strategy=desktop",
    "audit:seo": "node scripts/seo-structured-data-audit.mjs",
    "test:e2e:offline": "node ../scripts/web_offline_e2e_regression.mjs",
    "test:e2e:public-smoke": "node ../scripts/web_public_reader_smoke.mjs",
    "test:e2e:preview": "playwright test --config=playwright.config.ts tests/vercel-preview-smoke.spec.ts",
    "test:admin-article-reviews": "node ../scripts/admin_article_reviews_regression.mjs",
    "test:security-headers": "node scripts/assert-security-headers.mjs",
    "test:fluid-cpu": "node ../scripts/fluid_active_cpu_regression.mjs",
    "test:public-route-cpu-cache": "node ../scripts/public_route_cpu_cache_regression.mjs",
    "test:public-cache": "node ../scripts/public_cache_policy_regression.mjs",
    "test:article-dedupe": "node ../scripts/article_dedupe_regression.mjs",
    "test:admin-guardrails": "node ../scripts/admin_guardrails_regression.mjs",
    "test:admin-guardrails-cloudflare-forecast": "node ../scripts/admin_guardrails_cloudflare_forecast_regression.mjs",
    "test:admin-production-readiness": "node ../scripts/admin_production_readiness_regression.mjs",
    "test:admin-readiness-actions-token": "node ../scripts/admin_readiness_actions_token_contract.mjs",
    "analyze:homepage": "node scripts/homepage-performance-budget.mjs",
    "analyze:homepage:warn": "node scripts/homepage-performance-budget.mjs --warn-only",
    "audit:cache": "node scripts/cache-observability.mjs",
    "audit:cache:config": "node scripts/cache-observability.mjs --mode=config",
    "audit:translations": "node ../scripts/audit_article_translations.mjs"
  },
  "dependencies": {
    "@sentry/nextjs": "^10.59.0",
    "@supabase/supabase-js": "^2.108.2",
    "next": "16.2.9",
    "next-auth": "^5.0.0-beta.31",
    "react": "19.2.7",
    "react-dom": "19.2.7"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@lhci/cli": "^0.15.1",
    "@playwright/test": "^1.61.1",
    "@tailwindcss/postcss": "^4.3.1",
    "@types/node": "^26.0.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "eslint": "^9.39.4",
    "eslint-config-next": "16.2.9",
    "tailwindcss": "^4",
    "typescript": "^5.9.3"
  },
  "overrides": {
    "webpack": "5.108.0",
    "@sentry/bundler-plugin-core": {
      "glob": {
        "minimatch": {
          "brace-expansion": "5.0.7"
        }
      }
    },
    "@typescript-eslint/typescript-estree": {
      "minimatch": {
        "brace-expansion": "5.0.7"
      }
    },
    "fast-uri": "4.0.1",
    "postcss": "8.5.16",
    "tmp": "0.2.7",
    "uuid": "11.1.1"
  }
}
